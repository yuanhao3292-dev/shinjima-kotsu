{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "next build --webpack",
  "routes": [
    {
      "src": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(sqlmap|nikto|nmap|masscan|zgrab|nuclei|httpx|dirsearch|gobuster|ffuf|wfuzz).*"
        }
      ],
      "mitigate": {
        "action": "deny"
      }
    },
    {
      "src": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "x-react-router-prerender-data"
        }
      ],
      "mitigate": {
        "action": "deny"
      }
    },
    {
      "src": "/admin/(.*)",
      "missing": [
        {
          "type": "cookie",
          "key": "sb-fcpcjfqxxtxlbtvbjduk-auth-token.0"
        }
      ],
      "mitigate": {
        "action": "challenge"
      }
    }
  ],
  "crons": [
    {
      "path": "/api/cron/subscription-reminder",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/reset-quarterly-tiers",
      "schedule": "0 0 1 1,4,7,10 *"
    },
    {
      "path": "/api/cron/health-checkup-reminder",
      "schedule": "0 9 1 * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/admin/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/guide-partner/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/dashboard/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/my-account/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/my-orders/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' https://js.stripe.com https://va.vercel-scripts.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://fonts.loli.net https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com https://gstatic.loli.net https://cdn.jsdelivr.net; img-src 'self' data: https: blob:; media-src 'self' https://fcpcjfqxxtxlbtvbjduk.supabase.co blob:; connect-src 'self' https://niijima-koutsu.jp https://www.niijima-koutsu.jp https://bespoketrip.jp https://fonts.gstatic.com https://cdn.jsdelivr.net https://generativelanguage.googleapis.com https://api.deepseek.com https://api.stripe.com https://fcpcjfqxxtxlbtvbjduk.supabase.co wss://fcpcjfqxxtxlbtvbjduk.supabase.co https://va.vercel-scripts.com blob: data:; frame-src https://js.stripe.com https://hooks.stripe.com;"
        },
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    }
  ]
}
