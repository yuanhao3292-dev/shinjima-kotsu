# ============================================
# NIIJIMA KOTSU — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values.
# Required variables marked with [REQUIRED].

# --- Supabase (Auth & Database) ---
# https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co        # [REQUIRED]
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key                      # [REQUIRED]
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key                   # [REQUIRED]

# --- Stripe (Payment) ---
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx                                     # [REQUIRED]
STRIPE_WEBHOOK_SECRET=whsec_xxx                                   # [REQUIRED]
STRIPE_WEBHOOK_SECRET_MAIN=whsec_xxx                              # Production webhook

# --- AI / AEMC Pipeline ---
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-xxx                                      # [REQUIRED] For AEMC 4-AI pipeline
DEEPSEEK_API_KEY=sk-xxx                                           # Optional: DeepSeek fallback
GEMINI_API_KEY=xxx                                                # Optional: Google Gemini

# AEMC Feature Flags
AEMC_ENABLED=true                                                 # Enable AI health screening
AEMC_PIPELINE_MODE=lite                                           # "lite" (single model) or "full" (4-AI ensemble)

# --- Email (Resend) ---
# https://resend.com/api-keys
RESEND_API_KEY=re_xxx                                             # [REQUIRED]

# --- Security ---
ADMIN_EMAILS=admin@example.com                                    # [REQUIRED] Comma-separated admin emails
ADMIN_SECRET=your_admin_secret                                    # Admin API auth secret
ENCRYPTION_KEY=your-32-char-encryption-key-here                   # [REQUIRED] AES-256 PII encryption key (min 32 chars)
PII_ENCRYPTION_KEY=your-pii-encryption-key                        # Secondary PII key
CRON_SECRET=your_cron_secret                                      # Vercel cron job auth

# --- Rate Limiting (Upstash Redis) ---
# https://console.upstash.com/
# If not configured, falls back to in-memory (not suitable for production)
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token

# --- Monitoring (Sentry) ---
# https://sentry.io/ → Project Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_AUTH_TOKEN=sntrys_xxx                                      # For source map uploads

# --- EmailJS (Legacy, Optional) ---
EMAILJS_SERVICE_ID=your_service_id
EMAILJS_TEMPLATE_ID=your_template_id
EMAILJS_PUBLIC_KEY=your_public_key
